<div class="modal fade"
     id="generateTokenModal"
     tabindex="-1"
     data-bs-backdrop="static"
     data-bs-keyboard="false"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-top">

        <div class="modal-content token-modal-content">

            <div class="modal-header token-modal-header">

                <div>

                    <h4 class="modal-title">

                        <i class="bi bi-calendar-check me-2"></i>

                        Generate Appointment Token

                    </h4>

                    <small>
                        Book appointment for registered patient
                    </small>

                </div>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>

            </div>
           

            <input type="hidden"
                   id="patientId"
                   value="0" />
            <div class="modal-body">

                <div class="row g-4">

                    <!-- Search Patient -->
                    <div class="col-md-12">

                        <label class="form-label fw-semibold">
                            Search Patient
                        </label>

                        <select class="form-select"
                                id="patientSearch">
                        </select>

                    </div>

                    <!-- Patient Details Section -->
                    <div id="patientInfoSection"
                         style="display:none;">

                        <!-- Patient Details -->
                        <div class="row g-4 mt-1">

                            <div class="col-md-4">

                                <label class="form-label">
                                    Patient Name
                                </label>

                                <input type="text"
                                       class="form-control"
                                       id="patientName"
                                       readonly />

                            </div>

                            <div class="col-md-4">

                                <label class="form-label">
                                    Mobile Number
                                </label>

                                <input type="text"
                                       class="form-control"
                                       id="mobileNumber"
                                       readonly />

                            </div>

                            <div class="col-md-4">

                                <label class="form-label">
                                    Age
                                </label>

                                <input type="text"
                                       class="form-control"
                                       id="age"
                                       readonly />

                            </div>

                        </div>

                        <hr class="my-4" />

                        <!-- Symptoms Section -->
                        <div class="row g-4">                           

                            <div class="col-md-6"
                                 id="symptomsContainer">

                                <div class="d-flex justify-content-between align-items-center mb-2">

                                    <label class="form-label fw-semibold mb-0">
                                        Symptoms
                                    </label>

                                    <button type="button"
                                            class="btn btn-sm btn-danger d-none"
                                            id="clearSymptoms">

                                        Clear

                                    </button>

                                </div>

                                <div id="symptomsList"
                                     class="symptoms-box">
                                </div>

                                <small class="text-muted">
                                    Select patient symptoms
                                </small>

                            </div>


                            <!-- Other Symptoms -->
                            <div class="col-md-6"
                                 id="otherSymptomsContainer">

                                <div class="d-flex justify-content-between align-items-center">

                                    <label class="form-label fw-semibold mb-0">
                                        Other Symptoms
                                    </label>

                                    <button type="button"
                                            class="btn btn-sm btn-danger d-none"
                                            id="clearOtherSymptoms">

                                        Reset

                                    </button>

                                </div>

                                <textarea class="form-control"
                                          id="otherSymptoms"
                                          rows="2"
                                          placeholder="Enter patient complaint if symptom is not available"></textarea>

                                <small class="text-muted">
                                    Optional field for custom complaints
                                </small>

                            </div>



                        </div>

                        <hr class="my-4" />

                        <!-- Appointment Details -->
                        <div class="row g-4">                            

                            <!-- Priority -->
                            <div class="col-md-3 d-none"
                                 id="priorityContainer">

                                <label class="form-label">
                                    Priority
                                </label>

                                <select class="form-select"
                                        id="priorityId" disabled>

                                    <option value="">
                                        Select Priority
                                    </option>

                                    <option value="1">Low</option>
                                    <option value="2">Medium</option>
                                    <option value="3">High</option>
                                    <option value="4">Critical</option>

                                </select>

                                <small id="priorityWarning"
                                       class="text-danger">

                                    Symptom not found in the System. Please select the priority manually.

                                </small>

                            </div>

                            <!-- Department -->
                            <div class="col-md-3">

                                <label class="form-label">
                                    Department
                                </label>

                                <select class="form-select"
                                        id="departmentId">

                                    <option value="">
                                        Select Department
                                    </option>

                                </select>

                            </div>

                            <!-- Doctor -->
                            <div class="col-md-3">

                                <label class="form-label">
                                    Doctor
                                </label>

                                <select class="form-select"
                                        id="doctorId">

                                    <option value="">
                                        Select Doctor
                                    </option>

                                </select>

                            </div>

                            <!-- Appointment DateTime -->
                            <div class="col-md-3">

                                <label class="form-label fw-semibold">
                                    Appointment Date & Time
                                </label>

                                <div class="input-group">

                                    <span class="input-group-text">

                                        <i class="bi bi-calendar-event"></i>

                                    </span>

                                    <input type="datetime-local"
                                           class="form-control"
                                           id="appointmentDateTime"
                                           required />

                                </div>

                                <small class="text-muted">
                                    Select preferred appointment date and time
                                </small>

                            </div>



                            <!-- Visit Type -->
                            <div class="col-md-3">

                                <label class="form-label">
                                    Visit Type
                                </label>

                                <select class="form-select"
                                        id="visitType">

                                    <option value="Walk-In">
                                        Walk-In
                                    </option>

                                    <option value="Web">
                                        Web
                                    </option>

                                    <option value="Mobile">
                                        Mobile
                                    </option>

                                    <option value="Kiosk">
                                        Kiosk
                                    </option>

                                </select>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                    Cancel

                </button>

                <button type="button"
                        class="btn btn-primary"
                        id="btnSaveToken">

                    <i class="bi bi-check-circle me-1"></i>

                    Generate Token

                </button>

            </div>

        </div>

    </div>

</div>
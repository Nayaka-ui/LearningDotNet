.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card {
    border-radius: 15px;
}

.table thead tr th {
    background: #f8fafc;
    color: #334155;
    font-size: 14px;
    font-weight: 600;
}

.badge-active {
    background: #22c55e;
}

.badge-waiting {
    background: #f59e0b;
}

/* Modal top alignment */
.custom-patient-modal {
    margin-top: 60px;
    max-width: 1000px;
}

/* Modal Container */
.patient-modal-content {
    border: none;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,.18);
}

/* Header */
.patient-modal-header {
    background: linear-gradient(135deg, #2563eb, #1d4ed8);
    color: white;
    padding: 24px 30px;
}

.patient-modal-subtitle {
    opacity: .8;
    font-size: 14px;
}

/* Body */
.modal-body {
    background: #f8fafc;
}

/* Inputs */
.form-control,
.form-select {
    height: 48px;
    border-radius: 12px;
    border: 1px solid #dbe3ec;
    box-shadow: none;
}

    .form-control:focus,
    .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 .15rem rgba(37,99,235,.15);
    }

/* Input icons */
.input-group-text {
    border-radius: 12px 0 0 12px;
    background: white;
}

/* Footer */
.patient-modal-footer {
    padding: 20px 30px;
    border-top: 1px solid #e5e7eb;
    background: white;
}

    .patient-modal-footer .btn {
        min-width: 140px;
        border-radius: 10px;
        font-weight: 600;
    }

/* DataTables Customization */
.dataTables_wrapper {
    font-size: 14px;
}

.dataTables_filter {
    margin-bottom: 15px;
}

.dataTables_filter label {
    display: flex;
    align-items: center;
    gap: 10px;
}

.dataTables_filter input {
    border-radius: 8px !important;
    border: 1px solid #dbe3ec !important;
    padding: 8px 12px !important;
}

.dataTables_filter input:focus {
    border-color: #2563eb !important;
    box-shadow: 0 0 0 0.15rem rgba(37, 99, 235, 0.15) !important;
}

.dataTables_length {
    margin-bottom: 15px;
}

.dataTables_info {
    margin-top: 15px;
    font-size: 13px;
    color: #64748b;
}

.dataTables_paginate {
    margin-top: 15px;
}

.pagination {
    gap: 5px;
}

.paginate_button {
    padding: 6px 12px !important;
    border-radius: 6px !important;
    border: 1px solid #dbe3ec !important;
    cursor: pointer;
    transition: all 0.3s ease;
}

    .paginate_button:hover {
        background-color: #f1f5f9 !important;
        border-color: #2563eb !important;
    }

    .paginate_button.current {
        background-color: #2563eb !important;
        color: white !important;
        border-color: #2563eb !important;
    }

    .paginate_button.disabled {
        cursor: not-allowed;
        opacity: 0.5;
    }

.dt-empty {
    text-align: center;
    padding: 30px !important;
    color: #94a3b8;
}

/* Table row hover effect */
tbody tr {
    transition: background-color 0.3s ease;
}

    tbody tr:hover {
        background-color: #f8fafc;
    }

/* Action buttons */
.btn-info {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
    transition: all 0.3s ease;
}

    .btn-info:hover {
        background-color: #0284c7;
        border-color: #0284c7;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(14, 165, 233, 0.3);
    }
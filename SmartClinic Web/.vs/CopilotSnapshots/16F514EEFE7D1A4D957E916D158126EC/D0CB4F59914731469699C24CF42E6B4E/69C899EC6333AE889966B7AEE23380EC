@model List<SmartClinic.Web.Models.Patient.PatientDto>

@model List<SmartClinic.Web.Models.Patient.PatientDto>

@{
    ViewData["Title"] = "Patients";
    Layout = "_Layout";
}

<div class="container-fluid">

    <!-- Breadcrumb -->
    <div class="page-header">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item">
                        <a href="#"
                               class="text-decoration-none">
                            Smart Clinic
                        </a>
                    </li>
                    <li class="breadcrumb-item active">
                        Patient Management
                    </li>
                </ol>
            </nav>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary btn-sm"
                    id="btnAddPatient">

                <i class="bi bi-plus-lg me-1"></i>

                Add Patient

            </button>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h6 class="mb-0 fw-bold">
                        Patient List
                    </h6>
                </div>
                <div class="card-body">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            @ViewBag.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="patientsTable">
                            <thead>
                                <tr>
                                    <th>Sl.No</th>
                                    <th>Patient ID</th>
                                    <th>Patient Name</th>
                                    <th>Age</th>
                                    <th>Gender</th>
                                    <th>Mobile</th>
                                    <th>Symptoms</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Count > 0)
                                {
                                    @foreach (var patient in Model)
                                    {
                                        <tr>
                                            <td></td>
                                            <td>@patient.Uhid</td>
                                            <td>@patient.Name</td>
                                            <td>@patient.Age</td>
                                            <td>@patient.Gender</td>
                                            <td>@patient.MobileNumber</td>
                                            <td>@patient.Symptoms</td>
                                            <td>
                                                <button class="btn btn-sm btn-info" data-patient-id="@patient.Id">
                                                    <i class="bi bi-eye me-1"></i>View
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div id="patientModalContainer"></div>

        @section Scripts {
            <script src="~/js/patients-list.js" asp-append-version="true"></script>
        }
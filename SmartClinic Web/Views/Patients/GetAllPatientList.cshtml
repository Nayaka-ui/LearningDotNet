@model List<SmartClinic.Web.Models.Patient.PatientDto>

@{
    ViewData["Title"] = "Patients";
    Layout = "_Layout";
}



<!-- Breadcrumb -->
<div class="page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item">
                    <a href="#"
                       class="text-decoration-none">
                        Smart Clinic
                    </a>
                </li>
                <li class="breadcrumb-item active">
                    Patient Management
                </li>
            </ol>
        </nav>
    </div>

    <div class="d-flex gap-2">

        <!-- View All Appointments -->
        <button class="btn btn-outline-primary"
                id="btnViewAppointments">

            <i class="bi bi-calendar-check me-1"></i>

            View All Appointments

        </button>


        <button class="btn btn-primary btn-sm" id="btnAddPatient"> <i class="bi bi-plus-lg me-1"></i>Add Patient</button>
    </div>
</div>

    
<div class="col-12">

    <div class="card patient-card border-0 shadow-sm">

        <div class="card-header bg-white py-3 border-bottom">

            <div class="d-flex justify-content-between align-items-center">

                <h5 class="mb-0 fw-bold text-dark">
                    Patient List
                </h5>

            </div>

        </div>

        <div class="card-body">

            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">

                    <i class="bi bi-exclamation-circle me-2"></i>

                    @ViewBag.ErrorMessage

                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>

                </div>
            }

            <div class="table-responsive">

                <table class="table table-hover align-middle" id="patientsTable" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th style="width:70px">Sl.No</th>
                            <th>UHID</th>
                            <th>Patient Name</th>
                            <th>Age</th>
                            <th>Gender</th>
                            <th>Mobile</th>
                            @* <th>Symptoms</th> *@
                            <th style="width:120px">Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            @foreach (var patient in Model)
                            {
                                <tr>
                                    <td></td>
                                    <td>
                                        <span class="fw-semibold text-primary">
                                            @patient.Uhid
                                        </span>
                                    </td>

                                    <td>@patient.Name</td>
                                    <td>@patient.Age</td>
                                    <td><span class="badge bg-light text-dark border px-3 py-2">@patient.Gender</span></td>
                                    <td>@patient.MobileNumber</td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">

                                            <!-- View -->
                                            <button class="action-icon-btn btn-view"
                                                    data-patient-id="@patient.Id"
                                                    data-label="View">

                                                <i class="bi bi-eye">
                                                </i>

                                            </button>

                                            <!-- Edit -->
                                            <button class="action-icon-btn btn-edit"
                                                    data-patient-id="@patient.Id"
                                                    data-label="Edit">

                                                <i class="bi bi-pencil-square">
                                                </i>

                                            </button>

                                            <!-- Generate Token -->
                                            <button class="action-icon-btn btn-generate-token"
                                                    data-patient-id="@patient.Id"
                                                    data-patient-name="@patient.Name"
                                                    data-mobile="@patient.MobileNumber"
                                                    data-age="@patient.Age"
                                                    data-uhid="@patient.Uhid"
                                                    data-label="Generate Token"
                                                    title="Generate Token">

                                                <i class="bi bi-calendar-plus-fill">
                                                </i>

                                            </button>

                                            <!-- Delete -->
                                            <button class="action-icon-btn btn-delete"
                                                    data-patient-id="@patient.Id"
                                                    data-label="Delete">

                                                <i class="bi bi-trash">
                                                </i>

                                            </button>
                                        </div>
                                    </td>

                                        
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="bi bi-people fs-1 text-muted"></i>
                                    <h6 class="mt-3 text-muted">
                                        No Patients Found
                                    </h6>
                                </td>
                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>


<div id="patientModalContainer"></div>
<div id="tokenModalContainer"></div>


@section Scripts {
    <script src="~/js/appointments.js" asp-append-version="true"></script>
    <script src="~/js/patients-list.js" asp-append-version="true"></script>
}


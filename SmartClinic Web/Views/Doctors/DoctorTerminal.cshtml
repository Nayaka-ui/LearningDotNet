@{
    ViewData["Title"] = "Doctor Terminal";
}

<div class="doctor-terminal-container">   

    <!-- Statistics --> 

    <div class="stats-grid">

        <div class="stat-card">

            <span class="stat-title">
                TOTAL
            </span>

            <h2 id="totalCount">
                0
            </h2>

        </div>

        <div class="stat-card success">

            <span class="stat-title">
                COMPLETED
            </span>

            <h2 id="servedCount">
                0
            </h2>

        </div>

        <div class="stat-card warning">

            <span class="stat-title">
                WAITING
            </span>

            <h2 id="waitingCount">
                0
            </h2>

        </div>

        <div class="stat-card hold">

            <span class="stat-title">
                HOLD
            </span>

            <h2 id="holdCount">
                0
            </h2>

        </div>        

        <div class="stat-card danger">

            <span class="stat-title">
                SKIPPED
            </span>

            <h2 id="missedCount">
                0
            </h2>

        </div>

        <div class="stat-card review"
             id="btnWaitingReview"
             style="cursor:pointer;">

            <span class="stat-title">
                WAITING FOR REVIEW
            </span>

            <h2 id="reviewCount">
                0
            </h2>

        </div>

    </div>

    <!-- Queue Status Summary -->

    <div class="queue-status-strip">

        <div class="status-pill called">

            📞 Called

            <span id="calledCount">
                0
            </span>

        </div>

        <div class="status-pill lab">

            🧪 Lab

            <span id="labCount">
                0
            </span>

        </div>

        <div class="status-pill scan">

            🩻 Scan

            <span id="scanCount">
                0
            </span>

        </div>

        <div class="status-pill billing">

            💳 Billing

            <span id="billingCount">
                0
            </span>

        </div>

        <div class="status-pill paid">

            💰 Paid

            <span id="paidCount">
                0
            </span>

        </div>

        <div class="status-pill pharmacy">

            💊 Pharmacy

            <span id="pharmacyCount">
                0
            </span>

        </div>

        <div class="status-pill medicine-dispensed">

            <i class="fa-solid fa-capsules"></i>

            Medicines Dispensed

            <span id="MedicineDispensedCount">
                0
            </span>

        </div>

        <div class="status-pill admission">

            <i class="fa-solid fa-bed-pulse"></i>

            SendToAdmission

            <span id="SendToAdmitCount">
                0
            </span>

        </div>

        <div class="status-pill admitted">

            <i class="fa-solid fa-hospital-user"></i>

            Admitted

            <span id="AdmittedCount">
                0
            </span>

        </div>

    </div>

    <!-- Middle -->
    <div class="middle-grid">

        <!-- Actions -->
        <div class="action-panel">

            <div class="btn-row">
                <button id="callBtn" class="action-btn primary">📞 CALL</button>
                <button id="endBtn" class="action-btn danger">⏹ END</button>
                <button id="recallBtn" class="action-btn secondary">🔄 RECALL</button>
            </div>

            <div class="btn-row">
                <button id="holdBtn" class="action-btn warning">⏸ HOLD</button>
                <button id="skipBtn" class="action-btn dark">⏩ SKIP</button>
                <button id="nextBtn" class="action-btn primary">➡ NEXT</button>
            </div>

        </div>       

        <div id="currentlyCalledCard"
             class="current-call-card">

            <small>
                CURRENTLY CALLED
            </small>

            <h1 id="currentTicketId">
                —
            </h1>

            <h5 id="currentTicketName">
                No Active Call
            </h5>

        </div>

        <!-- Next Queue -->
        <div class="queue-card">

            <div class="card-header">

                NEXT 3 QUEUE

            </div>

            <div id="nextQueueList">
            </div>

        </div>

    </div>

    <!-- Bottom Queue -->
    <div class="bottom-grid">

        <div class="queue-card">

            <div class="card-header">
                WAITING QUEUE
            </div>

            <div id="waitingQueueList">
            </div>

        </div>

        <div class="queue-card">

            <div class="card-header">
                SKIPPED QUEUE
            </div>

            <div id="skippedQueueList">
            </div>

        </div>

        <div class="queue-card">

            <div class="card-header">
                HOLD QUEUE
            </div>

            <div id="holdQueueList">
            </div>

        </div>

    </div>

</div>

<audio id="reviewAlertSound"
       preload="auto">

    <source src="/audio/review-alert.mp3"
            type="audio/mpeg">

</audio>

<div id="consultationModalContainer"></div>


<div class="modal fade" id="waitingReviewModal" data-bs-keyboard="false" data-bs-backdrop="static">

    <div class="modal-dialog modal-lg">

        <div class="modal-content">

            <div class="modal-header">

                <h4>

                    Waiting For Review

                </h4>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <table class="table table-bordered">

                    <thead>

                        <tr>

                            <th>
                                Token
                            </th>

                            <th>
                                Patient
                            </th>

                            <th>
                                Action
                            </th>

                        </tr>

                    </thead>

                    <tbody id="tblWaitingReviewBody">
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<div class="modal fade"
     id="addMedicineModal"
     tabindex="-1">

    <div class="modal-dialog modal-md">

        <div class="modal-content">

            <div class="modal-header">

                <h4>

                    <i class="fa-solid fa-capsules"></i>

                    Add New Medicine

                </h4>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>

            </div>

            <div class="modal-body">

                <div class="mb-3">

                    <label class="form-label">

                        Medicine Name

                    </label>

                    <input type="text"
                           id="txtMedicineName"
                           class="form-control"
                           placeholder="Enter medicine name" />

                </div>

                <div class="row">

                    <div class="col-md-6">

                        <label class="form-label">

                            Strength

                        </label>

                        <input type="text"
                               id="txtStrength"
                               class="form-control"
                               placeholder="650 MG" />

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">

                            Type

                        </label>

                        <select id="ddlMedicineType"
                                class="form-select">

                            <option value="Tablet">
                                Tablet
                            </option>

                            <option value="Capsule">
                                Capsule
                            </option>

                            <option value="Syrup">
                                Syrup
                            </option>

                            <option value="Injection">
                                Injection
                            </option>

                            <option value="Drops">
                                Drops
                            </option>

                        </select>

                    </div>

                </div>

                <div class="mt-3">

                    <label class="form-label">

                        Price

                    </label>

                    <input type="number"
                           id="txtMedicinePrice"
                           class="form-control"
                           placeholder="Price" />

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-primary"
                        id="btnSaveMedicine">

                    <i class="fa-solid fa-floppy-disk"></i>

                    Save Medicine

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <script src="~/js/doctor-terminal.js" asp-append-version="true"></script>
}

@{
    ViewData["Title"] = "Pharmacy Queue";
}

<div class="card shadow-sm border-0">

    <div class="card-header bg-white">

        <h3 class="mb-0">

            Pharmacy Queue

        </h3>

    </div>

    <div class="card-body">

        <table class="table table-bordered align-middle"
               id="tblPharmacyQueue"
               style="width:100%">

            <thead>

                <tr>

                    <th>
                        Token No
                    </th>

                    <th>
                        Patient Name
                    </th>

                    <th>
                        Prescription
                    </th>

                    <th>
                        Action
                    </th>

                </tr>

            </thead>

            <tbody>
            </tbody>

        </table>

    </div>

</div>

<partial name="_DispenseMedicineModal" />

@section Scripts
{
    <script src="~/js/pharmacyqueue.js" asp-append-version="true"></script>
}
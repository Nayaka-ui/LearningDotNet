                        Email = u.Email,
                        Username = u.Username,
                        PasswordHash = u.PasswordHash,
                        RoleId = u.RoleId,
                        IsDeleted = u.IsDeleted,
                        CreatedDateTime = u.CreatedDateTime,
                        CreatedBy = u.CreatedBy,
                        UpdatedDateTime = u.UpdatedDateTime,
                        UpdatedBy = u.UpdatedBy,
                        RoleName = u.Role.Name,
                        RolesDto = new RolesDto
                        {
                            Id = u.Role.Id,
                            Name = u.Role.Name,
                            IsDeleted = u.Role.IsDeleted
                        }
                    })
                    .ToListAsync();
                return users;
            }
            catch (Exception ex)
            {
                // Log the exception (you can use a logging framework like Serilog, NLog, etc.)
                Console.WriteLine($"An error occurred while fetching users: {ex.Message}");
                // Return an empty list or handle it as per your application's requirements
                return await Task.FromResult(new List<UserDto>());
            }
        }

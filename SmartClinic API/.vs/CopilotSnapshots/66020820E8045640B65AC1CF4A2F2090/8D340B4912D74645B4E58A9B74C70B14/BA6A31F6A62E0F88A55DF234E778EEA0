        [HttpGet("GetDoctorQueue")]
        public async Task<IActionResult> GetDoctorQueue(int doctorId)
        {
            try
            {
                var result = await _doctorService.GetDoctorQueueAsync(doctorId);

                if (result == null)
                {
                    return BadRequest(
                        new
                        {
                            success = false,
                            message = "Doctor not found"
                        });
                }

                return Ok(new
                {
                    success = true,
                    data = result
                });
            }
            catch (Exception ex)
            {
                return BadRequest(new
                {
                    success = false,
                    message = ex.Message
                });
            }
        }

